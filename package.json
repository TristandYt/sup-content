{
  "name": "sup-content",
  "version": "1.0.0",
  "description": "Plateforme Sup Content - Monorepo",
  "private": true,
  "scripts": {
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "build": "docker compose up -d --build",
    "logs": "docker compose logs -f",
    "api-logs": "docker compose logs -f supcontent-api",
    "clean": "docker compose down -v --rmi all",
    "test": "jest"
  },
  "devDependencies": {
    "firebase-tools": "^15.10.1",
    "jest": "^29.0.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "zod": "^4.3.6"
  }
}
