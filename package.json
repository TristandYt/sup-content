{
  "name": "sup-content",
  "version": "1.0.0",
  "description": "Plateforme Sup Content - Monorepo",
  "private": true,
  "scripts": {
    "start": "docker compose up -d",
    "stop": "docker compose down",
    "build": "docker compose up -d --build",
    "logs": "docker compose logs -f",
    "api-logs": "docker compose logs -f supcontent-api",
    "clean": "docker compose down -v --rmi all",
    "test": "jest --config=backend/tests/jest.config.js --forceExit --detectOpenHandles",
    "test:verbose": "jest --config=backend/tests/jest.config.js --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --config=backend/tests/jest.config.js --watch",
    "test:filter": "jest --config=backend/tests/jest.config.js --forceExit --testNamePattern"
  },
  "devDependencies": {
    "firebase-tools": "^15.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.9.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  }
}
