# ==========================================
# Configuration Serveur
# ==========================================
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ==========================================
# API IGDB (Twitch)
# Obtenez vos clés sur https://dev.twitch.tv/login
# ==========================================
IGDB_CLIENT_ID=votre_client_id_igdb_ici
IGDB_CLIENT_SECRET=votre_client_secret_igdb_ici

# ==========================================
# Émulateurs Firebase (Développement Local)
# ==========================================
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099